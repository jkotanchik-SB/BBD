---
/* Latest News & Alerts section */
interface NewsItem {
  title: string;
  date: string;
  excerpt: string;
  href: string;
}

const newsItems: NewsItem[] = [
  {
    title: "MADiE User Group",
    date: "Apr 18, 2025",
    excerpt:
      "The MADiE User Group is an open forum to discuss the status of the tools and gather feedback from the user community.",
    href: "https://www.emeasuretool.cms.gov/news-alerts/madie-user-group-0",
  },
  {
    title: "MADiE User Group",
    date: "Apr 30, 2024",
    excerpt:
      "The MADiE User Group is an open forum to discuss the status of the tools and gather feedback from the user community.",
    href: "https://www.emeasuretool.cms.gov/news-alerts/madie-user-group",
  },
  {
    title: "MAT and Bonnie Migration – Action Needed",
    date: "Mar 8, 2024",
    excerpt:
      "Important announcement from CMS: MAT and Bonnie decommissioning date finalized — June 28, 2024.",
    href: "https://www.emeasuretool.cms.gov/news-alerts/mat-and-bonnie-migration-action-needed",
  },
];
---
<section class="news" aria-label="Latest News and Alerts">
  <div class="container">
    <div class="news__header">
      <h2 class="news__heading">Latest News &amp; Alerts</h2>
      <a href="https://www.emeasuretool.cms.gov/news-alerts" class="news__view-all">VIEW ALL</a>
    </div>

    <div class="news__grid">
      {newsItems.map((item) => (
        <article class="news-card">
          <h3 class="news-card__title">{item.title}</h3>
          <time class="news-card__date">{item.date}</time>
          <p class="news-card__excerpt">{item.excerpt}</p>
          <a href={item.href} class="news-card__link">READ MORE</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .news {
    padding: 4rem 0;
    background: var(--color-base-lightest);
  }
  .news__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }
  .news__heading {
    font-size: 1.75rem;
    color: var(--color-primary-darker);
  }
  .news__view-all {
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .news__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .news-card {
    background: var(--color-white);
    padding: 1.75rem;
    border-radius: 6px;
    border-top: 4px solid var(--color-primary);
    display: flex;
    flex-direction: column;
  }
  .news-card__title {
    font-size: 1.15rem;
    color: var(--color-primary-darker);
    margin-bottom: 0.5rem;
  }
  .news-card__date {
    font-size: 0.85rem;
    color: var(--color-base);
    margin-bottom: 1rem;
  }
  .news-card__excerpt {
    font-size: 0.95rem;
    color: var(--color-base-dark);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .news-card__link {
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }

  @media (max-width: 900px) {
    .news__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .news__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
