---
import { getResources, resourceUrl } from "../lib/cms";

const [releaseNotes, slides, userGuides] = await Promise.all([
  getResources("release-notes"),
  getResources("user-group-slides"),
  getResources("user-guides"),
]);

const allItems = [...releaseNotes, ...slides, ...userGuides];

// Sort by releaseDate descending; items without a date fall to the end
const sorted = allItems.sort((a, b) => {
  if (a.releaseDate && b.releaseDate) {
    return new Date(b.releaseDate).getTime() - new Date(a.releaseDate).getTime();
  }
  if (a.releaseDate) return -1;
  if (b.releaseDate) return 1;
  return 0;
});

const newsItems = sorted.slice(0, 3);

const sectionLabel: Record<string, string> = {
  "release-notes": "Release Notes",
  "user-group-slides": "User Group",
  "user-guides": "User Guide",
};

function formatDate(iso?: string): string {
  if (!iso) return "";
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}
---
<section class="news" aria-label="Latest News and Alerts">
  <div class="container">
    <div class="news__header">
      <h2 class="news__heading">Latest News &amp; Alerts</h2>
      <a href="/news-alerts" class="news__view-all">VIEW ALL</a>
    </div>

    <div class="news__grid">
      {newsItems.map((item) => {
        const href = resourceUrl(item);
        const isReal = href !== "#";
        const label = sectionLabel[item.section] ?? item.section;
        return (
          <article class="news-card">
            <div class="news-card__meta">
              <time class="news-card__date">{formatDate(item.releaseDate)}</time>
              <span class="news-card__tag">{label}</span>
            </div>
            <h3 class="news-card__title">{item.title}</h3>
            <p class="news-card__excerpt">{item.description}</p>
            {isReal ? (
              <a href={href} class="news-card__link" target="_blank" rel="noopener noreferrer">READ MORE</a>
            ) : (
              <span class="news-card__link news-card__link--none">No link available</span>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .news {
    padding: 4rem 0;
    background: var(--color-base-lightest);
  }
  .news__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }
  .news__heading {
    font-size: 1.75rem;
    color: var(--color-primary-darker);
  }
  .news__view-all {
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .news__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .news-card {
    background: var(--color-white);
    padding: 1.75rem;
    border-radius: 6px;
    border-top: 4px solid var(--color-primary);
    display: flex;
    flex-direction: column;
  }
  .news-card__meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .news-card__tag {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-primary-lightest, #e8f1fa);
    color: var(--color-primary-dark);
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
  }
  .news-card__title {
    font-size: 1.15rem;
    color: var(--color-primary-darker);
    margin-bottom: 0.5rem;
  }
  .news-card__date {
    font-size: 0.85rem;
    color: var(--color-base);
  }
  .news-card__excerpt {
    font-size: 0.95rem;
    color: var(--color-base-dark);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .news-card__link {
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }
  .news-card__link--none {
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-base-light);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .news__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .news__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
