---
/* US Gov banner — "An official website of the United States government" */
---
<section class="gov-banner" aria-label="Official government website">
  <div class="container gov-banner__inner">
    <div class="gov-banner__header">
      <img
        class="gov-banner__flag"
        src="/images/us-flag-small.png"
        alt="U.S. flag"
        width="20"
        height="14"
        loading="lazy"
      />
      <p class="gov-banner__text">
        An official website of the United States government.
        <button
          class="gov-banner__toggle"
          aria-expanded="false"
          aria-controls="gov-banner-info"
        >
          Here's how you know
        </button>
      </p>
    </div>
  </div>

  <div id="gov-banner-info" class="gov-banner__info" hidden>
    <div class="container gov-banner__info-inner">
      <div class="gov-banner__info-item">
        <img src="/images/icon-dot-gov.svg" alt="" width="40" height="40" class="gov-banner__info-icon" />
        <div>
          <strong>Official websites use .gov</strong>
          <p>A <strong>.gov</strong> website belongs to an official government organization in the United States.</p>
        </div>
      </div>
      <div class="gov-banner__info-item">
        <img src="/images/icon-https.svg" alt="" width="40" height="40" class="gov-banner__info-icon" />
        <div>
          <strong>Secure .gov websites use HTTPS</strong>
          <p>A <strong>lock</strong> or <strong>https://</strong> means you've safely connected to the .gov website.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gov-banner {
    background: var(--color-gov-banner-bg);
    font-size: 0.8rem;
    border-bottom: 1px solid var(--color-base-lighter);
  }
  .gov-banner__inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  .gov-banner__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
  }
  .gov-banner__flag {
    flex-shrink: 0;
  }
  .gov-banner__text {
    color: var(--color-base-dark);
  }
  .gov-banner__toggle {
    background: none;
    border: none;
    color: var(--color-primary);
    text-decoration: underline;
    cursor: pointer;
    font-size: 0.8rem;
    padding: 0;
    margin-left: 0.25rem;
  }
  .gov-banner__info {
    background: var(--color-gov-banner-bg);
    padding: 1rem 0;
  }
  .gov-banner__info-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .gov-banner__info-item p {
    margin-top: 0.25rem;
    color: var(--color-base-dark);
  }
  .gov-banner__info-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .gov-banner__info-icon {
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .gov-banner__info-inner {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.gov-banner__toggle');
  const info = document.getElementById('gov-banner-info');
  if (toggle && info) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      info.hidden = expanded;
    });
  }
</script>
