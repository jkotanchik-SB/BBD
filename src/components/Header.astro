---
/* Site header with logo and navigation */
const navLinks = [
  { label: "Home", href: "/" },
  { label: "Training & Resources", href: "/training-resources" },
  { label: "News & Alerts", href: "/news-alerts" },
  { label: "About", href: "/about" },
];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo-link">
      <img src="/images/logo-cms.png" alt="CMS Logo" class="site-header__logo-img" width="117" height="40" />
      <span class="site-header__logo-text">
        <span class="site-header__logo-abbr">MADiE</span>
        <span class="site-header__logo-full">Measure Authoring Development Integrated Environment</span>
      </span>
    </a>

    <button class="site-header__menu-btn" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-nav">
      <span class="site-header__menu-icon"></span>
    </button>

    <nav id="primary-nav" class="site-header__nav" aria-label="Primary navigation">
      <ul class="site-header__nav-list">
        {navLinks.map((link) => (
          <li class="site-header__nav-item">
            <a href={link.href} class="site-header__nav-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-primary-darker);
    color: var(--color-white);
    padding: 0;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 64px;
    flex-wrap: wrap;
  }
  .site-header__logo-link {
    color: var(--color-white);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
  }
  .site-header__logo-link:hover {
    color: var(--color-base-lighter);
  }
  .site-header__logo-img {
    height: 40px;
    width: auto;
  }
  .site-header__logo-abbr {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .site-header__logo-full {
    font-size: 0.75rem;
    display: block;
    max-width: 200px;
    line-height: 1.3;
    opacity: 0.85;
  }
  .site-header__menu-btn {
    display: none;
    background: none;
    border: 2px solid var(--color-white);
    color: var(--color-white);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .site-header__menu-icon::after {
    content: "Menu";
  }
  .site-header__nav-list {
    display: flex;
    list-style: none;
    gap: 0;
    margin: 0;
    padding: 0;
  }
  .site-header__nav-link {
    display: block;
    color: var(--color-white);
    text-decoration: none;
    padding: 1.25rem 1rem;
    font-size: 0.925rem;
    font-weight: 600;
    border-bottom: 4px solid transparent;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .site-header__nav-link:hover {
    background: rgba(255, 255, 255, 0.08);
    border-bottom-color: var(--color-white);
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .site-header__menu-btn {
      display: block;
    }
    .site-header__nav {
      width: 100%;
      display: none;
    }
    .site-header__nav.open {
      display: block;
    }
    .site-header__nav-list {
      flex-direction: column;
    }
    .site-header__nav-link {
      border-bottom: none;
      border-left: 4px solid transparent;
      padding: 0.75rem 1rem;
    }
    .site-header__nav-link:hover {
      border-left-color: var(--color-white);
      border-bottom-color: transparent;
    }
  }
</style>

<script>
  const menuBtn = document.querySelector('.site-header__menu-btn');
  const nav = document.getElementById('primary-nav');
  if (menuBtn && nav) {
    menuBtn.addEventListener('click', () => {
      const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('open');
    });
  }
</script>
