---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<div class="page-hero">
  <div class="container">
    <h1 class="page-hero__title">{title}</h1>
    {subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
  </div>
</div>

<style>
  .page-hero {
    background: var(--color-primary-darker);
    color: var(--color-white);
    padding: 2.5rem 0;
    border-bottom: 4px solid var(--color-primary);
  }
  .page-hero__title {
    font-size: 2rem;
    font-weight: 700;
  }
  .page-hero__subtitle {
    margin-top: 0.5rem;
    font-size: 1.1rem;
    opacity: 0.85;
  }
</style>
