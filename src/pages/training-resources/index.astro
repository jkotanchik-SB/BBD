---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { getResources, groupByYear, resourceUrl } from "../../lib/cms";

// Fetch all sections in parallel from the CMS server
const [userGuides, releaseNotes, additionalResources, faqItems, videoTutorials, userGroupSlides] =
  await Promise.all([
    getResources("user-guides"),
    getResources("release-notes"),
    getResources("additional-resources"),
    getResources("faqs"),
    getResources("video-tutorials"),
    getResources("user-group-slides"),
  ]);

// Group release notes by year; sort numeric years descending, "Other" last
const releaseNotesByYear = groupByYear(releaseNotes);
const releaseYears = Object.keys(releaseNotesByYear).sort((a, b) => {
  const na = Number(a), nb = Number(b);
  if (!isNaN(na) && !isNaN(nb)) return nb - na;
  if (!isNaN(na)) return -1;
  if (!isNaN(nb)) return 1;
  return 0;
});

// Group user group slides by year, sorted descending
const slidesByYear = groupByYear(userGroupSlides);
const slideYears = Object.keys(slidesByYear).sort((a, b) => {
  const na = Number(a), nb = Number(b);
  if (!isNaN(na) && !isNaN(nb)) return nb - na;
  if (!isNaN(na)) return -1;
  if (!isNaN(nb)) return 1;
  return 0;
});
---
<BaseLayout title="Training & Resources | MADiE">
  <PageHero title="Training & Resources" />

  <div class="tr-layout">
    <div class="container tr-layout__inner">
      <!-- Main content column -->
      <main class="tr-main">

        <!-- FAQs (from CMS `faqs` section) -->
        <section class="tr-section" id="faq">
          <h2 class="tr-section__heading">Frequently Asked Questions</h2>
          <div class="faq-list">
            {faqItems.map((faq) => (
              <details class="faq-item">
                <summary class="faq-item__question">{faq.title}</summary>
                <div class="faq-item__answer">
                  {faq.description}
                  {faq.url && faq.url !== '#' && (
                    <p><a href={faq.url}>{faq.url}</a></p>
                  )}
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- User Guide -->
        <section class="tr-section" id="user-guide">
          <h2 class="tr-section__heading">User Guide</h2>
          <p>The MADiE User Guide provides step-by-step instructions on the tool, including but not limited to:</p>
          <ul class="tr-list">
            <li>Creation and Maintenance of Measures and Libraries</li>
            <li>Creation and Maintenance of Test Cases</li>
            <li>Measure Versioning</li>
            <li>Measure and Test Case Exports</li>
          </ul>
          <p>If additional assistance is required, please visit the <a href="/contact-us">Contact Us</a> page for information on the MADiE Support Desk.</p>
        </section>

        <!-- CQL -->
        <section class="tr-section" id="cql">
          <h2 class="tr-section__heading">Clinical Quality Language (CQL)</h2>
          <p>
            The Centers for Medicare &amp; Medicaid Services (CMS) has announced that electronic clinical quality measures (eCQMs) in CMS quality programs will be transitioned to use the Clinical Quality Language (CQL) standard (CQL Release 1, Standard for Trial Use (STU) 4) for logic expression. CQL is a Health Level Seven International standard and aims to unify the expression of logic for eCQMs and Clinical Decision Support (CDS). CQL provides the ability to better express logic defining measure populations to improve the accuracy and clarity of eCQMs.
          </p>
          <p>For additional information regarding CQL, please visit the eCQI resource center at <a href="https://ecqi.healthit.gov/">ecqi.healthit.gov</a>.</p>
        </section>

        <!-- MADiE User Group (from CMS `user-group-slides` section) -->
        <section class="tr-section" id="user-group">
          <h2 class="tr-section__heading">MADiE User Group</h2>
          <p>
            <a href="https://zoom.us/meeting/register/QMqsAWSaQq6Ed8NC0tl2Ew#/registration">Register for MADiE User Group</a>
          </p>
          {slideYears.map((year) => (
            <>
              <h3 class="tr-section__subheading">{year}</h3>
              <ul class="tr-link-list">
                {slidesByYear[year].map((slide) => (
                  <li><a href={resourceUrl(slide)} target="_blank" rel="noopener noreferrer">{slide.title}</a></li>
                ))}
              </ul>
            </>
          ))}
          <p><a href="https://www.emeasuretool.cms.gov/archived-bonnie-mat-madie-user-group-slides">Archived Bonnie, MAT, MADiE User Group Slides</a></p>
        </section>

        <!-- Did You Know (from CMS `video-tutorials` section) -->
        <section class="tr-section" id="did-you-know">
          <h2 class="tr-section__heading">Did You Know?</h2>
          <ul class="tr-link-list">
            {videoTutorials.map((video) => (
              <li><a href={resourceUrl(video)}>{video.title}</a></li>
            ))}
          </ul>
        </section>

      </main>

      <!-- Sidebar -->
      <aside class="tr-sidebar">

        <!-- Helpful Links from CMS `additional-resources` section -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">MADiE Helpful Links</h2>
          <ul class="sidebar-card__list">
            {additionalResources.map((r) => (
              <li><a href={resourceUrl(r)}>{r.title}</a></li>
            ))}
          </ul>
        </div>

        <!-- MADiE Resources from CMS `user-guides` section -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">MADiE Resources</h2>
          <ul class="sidebar-card__list">
            {userGuides.map((r) => (
              <li><a href={resourceUrl(r)}>{r.title}</a></li>
            ))}
          </ul>
        </div>

        <!-- Release Notes from CMS `release-notes` section -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">Release Notes</h2>
          {releaseYears.map((year) => (
            <>
              <h3 class="sidebar-card__year">{year}</h3>
              <ul class="sidebar-card__list">
                {releaseNotesByYear[year].map((r) => (
                  <li><a href={resourceUrl(r)}>{r.title}</a></li>
                ))}
              </ul>
            </>
          ))}
          <p><a href="https://www.emeasuretool.cms.gov/archived-madie-release-notes">Archived MADiE Release Notes</a></p>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">Contact Us</h2>
          <p>MADiE access: <a href="mailto:MADiE@cms.hhs.gov">MADiE@cms.hhs.gov</a></p>
          <p>Measure and/or test case development: <a href="https://oncprojectracking.healthit.gov/support/projects/MADIE/summary">Submit a JIRA ticket</a></p>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .tr-layout {
    padding: 3rem 0;
    background: var(--color-white);
  }
  .tr-layout__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }
  .tr-section {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-base-lighter);
  }
  .tr-section:last-child {
    border-bottom: none;
  }
  .tr-section__heading {
    font-size: 1.5rem;
    color: var(--color-primary-darker);
    margin-bottom: 1rem;
  }
  .tr-section__subheading {
    font-size: 1.1rem;
    color: var(--color-primary-dark);
    margin: 1.25rem 0 0.5rem;
  }
  .tr-section p {
    color: var(--color-base-dark);
    line-height: 1.7;
    margin-bottom: 0.75rem;
    max-width: 72ch;
  }
  .tr-list {
    padding-left: 1.5rem;
    margin: 0.75rem 0;
    color: var(--color-base-dark);
    line-height: 1.8;
  }
  .tr-link-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  .tr-link-list li {
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--color-base-lightest);
  }
  .tr-link-list li:last-child {
    border-bottom: none;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    border: 1px solid var(--color-base-lighter);
    border-radius: 4px;
  }
  .faq-item__question {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: var(--color-primary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item__question::after {
    content: "+";
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  details[open] .faq-item__question::after {
    content: "−";
  }
  .faq-item__answer {
    padding: 0 1.25rem 1rem;
    color: var(--color-base-dark);
    line-height: 1.7;
  }

  /* Sidebar */
  .tr-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-card {
    background: var(--color-base-lightest);
    border-left: 4px solid var(--color-primary);
    padding: 1.25rem;
    border-radius: 0 4px 4px 0;
  }
  .sidebar-card__heading {
    font-size: 1.1rem;
    color: var(--color-primary-darker);
    margin-bottom: 0.75rem;
  }
  .sidebar-card__year {
    font-size: 0.9rem;
    color: var(--color-base-dark);
    font-weight: 700;
    margin: 0.75rem 0 0.25rem;
  }
  .sidebar-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sidebar-card__list li {
    padding: 0.3rem 0;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--color-base-lighter);
  }
  .sidebar-card__list li:last-child {
    border-bottom: none;
  }
  .sidebar-card p {
    font-size: 0.9rem;
    color: var(--color-base-dark);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 900px) {
    .tr-layout__inner {
      grid-template-columns: 1fr;
    }
    .tr-sidebar {
      order: -1;
    }
  }
</style>
