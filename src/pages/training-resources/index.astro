  { label: "MADiE Version Information", href: "https://www.emeasuretool.cms.gov/sites/default/files/2026-03/MADiE%20Version%20Information_v2.24.pdf" },
  { label: "MADiE Recognized FHIR Code Systems", href: "https://www.emeasuretool.cms.gov/sites/default/files/2024-09/MADiE%20Recognized%20FHIR%20Code%20Systems_v1.1_0.xlsx" },
