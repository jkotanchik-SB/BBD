  { label: "QI-Core Test Case Creation & Editing (Video)", href: "https://www.youtube.com/watch?v=29qox1tyUZE&list=PLaV7m2-zFKpis3s9BzxwWH48DbGdfasIl&index=3" },
  { label: "QI-Core STU6 Test Case Validation (Video)", href: "https://www.youtube.com/watch?v=Z7Bw1rY-x-Y" },
];

const faqs = [
  {
    q: "How do I access the Measure Authoring Development Integrated Environment (MADiE)?",
    a: `All MADiE users are required to have a valid HCQIS Access Roles and Profiles (HARP) ID. Once you have a valid HARP ID, you may log into your HARP account at <a href="https://harp.cms.gov">harp.cms.gov</a> and request the MADiE-User role. Detailed instructions for requesting the MADiE-User role are available in the MADiE Access Guide. After receiving an email confirming your MADiE-User role request has been approved, you will be able to use your HARP ID and password to log into MADiE at <a href="https://madie.cms.gov">madie.cms.gov</a>.`,
  },
  {
    q: "Where can I learn more about measure authoring and test case development in MADiE?",
    a: `The MADiE User Guide offers detailed information about the functionality available for the purpose of measure authoring and test case development in MADiE. Click on the MADiE User Guide link under <em>MADiE Resources</em> in the right pane on this page.`,
  },
  {
    q: "Where can I learn more about writing JSON test cases in MADiE?",
    a: `Please review the JSON Test Case Guide for guidance regarding exporting test cases from BONNIE FHIR, writing JSON test cases, entering JSON test cases into MADiE, defining expected results of test cases in MADiE, and more. Click on the JSON Test Case Guide under <em>MADiE Resources</em> in the right pane on this page.`,
  },
  {
    q: "How do I share a measure I own and all test cases in MADiE with another MADiE user?",
    a: `To share a measure and all test cases for the measure, the measure owner must complete the Measure Sharing Request Form and submit it via email to the Helpdesk at <a href="mailto:MADiE@cms.hhs.gov">MADiE@cms.hhs.gov</a>. <strong>This form must be submitted via email and NOT submitted using the Bonnie MAT MADiE Jira Issue tracker as it contains HARP IDs.</strong>`,
  },
];
---
<BaseLayout title="Training & Resources | MADiE">
  <PageHero title="Training & Resources" />

  <div class="tr-layout">
    <div class="container tr-layout__inner">
      <!-- Main content column -->
      <main class="tr-main">

        <!-- FAQs -->
        <section class="tr-section" id="faq">
          <h2 class="tr-section__heading">Frequently Asked Questions</h2>
          <div class="faq-list">
            {faqs.map((faq) => (
              <details class="faq-item">
                <summary class="faq-item__question">{faq.q}</summary>
                <div class="faq-item__answer" set:html={faq.a} />
              </details>
            ))}
          </div>
        </section>

        <!-- User Guide -->
        <section class="tr-section" id="user-guide">
          <h2 class="tr-section__heading">User Guide</h2>
          <p>The MADiE User Guide provides step-by-step instructions on the tool, including but not limited to:</p>
          <ul class="tr-list">
            <li>Creation and Maintenance of Measures and Libraries</li>
            <li>Creation and Maintenance of Test Cases</li>
            <li>Measure Versioning</li>
            <li>Measure and Test Case Exports</li>
          </ul>
          <p>If additional assistance is required, please visit the <a href="/contact-us">Contact Us</a> page for information on the MADiE Support Desk.</p>
        </section>

        <!-- CQL -->
        <section class="tr-section" id="cql">
          <h2 class="tr-section__heading">Clinical Quality Language (CQL)</h2>
          <p>
            The Centers for Medicare &amp; Medicaid Services (CMS) has announced that electronic clinical quality measures (eCQMs) in CMS quality programs will be transitioned to use the Clinical Quality Language (CQL) standard (CQL Release 1, Standard for Trial Use (STU) 4) for logic expression. CQL is a Health Level Seven International standard and aims to unify the expression of logic for eCQMs and Clinical Decision Support (CDS). CQL provides the ability to better express logic defining measure populations to improve the accuracy and clarity of eCQMs.
          </p>
          <p>For additional information regarding CQL, please visit the eCQI resource center at <a href="https://ecqi.healthit.gov/">ecqi.healthit.gov</a>.</p>
        </section>

        <!-- MADiE User Group -->
        <section class="tr-section" id="user-group">
          <h2 class="tr-section__heading">MADiE User Group</h2>
          <p>
            <a href="https://zoom.us/meeting/register/QMqsAWSaQq6Ed8NC0tl2Ew#/registration">Register for MADiE User Group</a>
          </p>
          <h3 class="tr-section__subheading">2026</h3>
          <ul class="tr-link-list">
            {userGroupSlides2026.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
          <h3 class="tr-section__subheading">2025</h3>
          <ul class="tr-link-list">
            {userGroupSlides2025.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
          <p><a href="https://www.emeasuretool.cms.gov/archived-bonnie-mat-madie-user-group-slides">Archived Bonnie, MAT, MADiE User Group Slides</a></p>
        </section>

        <!-- Did You Know -->
        <section class="tr-section" id="did-you-know">
          <h2 class="tr-section__heading">Did You Know?</h2>
          <ul class="tr-link-list">
            {didYouKnow.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </section>

      </main>

      <!-- Sidebar -->
      <aside class="tr-sidebar">

        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">MADiE Helpful Links</h2>
          <ul class="sidebar-card__list">
            {helpfulLinks.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">MADiE Resources</h2>
          <ul class="sidebar-card__list">
            {resources.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">Release Notes</h2>
          <h3 class="sidebar-card__year">2026</h3>
          <ul class="sidebar-card__list">
            {releaseNotes2026.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
          <h3 class="sidebar-card__year">2025</h3>
          <ul class="sidebar-card__list">
            {releaseNotes2025.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
          <p><a href="https://www.emeasuretool.cms.gov/archived-madie-release-notes">Archived MADiE Release Notes</a></p>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__heading">Contact Us</h2>
          <p>MADiE access: <a href="mailto:MADiE@cms.hhs.gov">MADiE@cms.hhs.gov</a></p>
          <p>Measure and/or test case development: <a href="https://oncprojectracking.healthit.gov/support/projects/MADIE/summary">Submit a JIRA ticket</a></p>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .tr-layout {
    padding: 3rem 0;
    background: var(--color-white);
  }
  .tr-layout__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }
  .tr-section {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-base-lighter);
  }
  .tr-section:last-child {
    border-bottom: none;
  }
  .tr-section__heading {
    font-size: 1.5rem;
    color: var(--color-primary-darker);
    margin-bottom: 1rem;
  }
  .tr-section__subheading {
    font-size: 1.1rem;
    color: var(--color-primary-dark);
    margin: 1.25rem 0 0.5rem;
  }
  .tr-section p {
    color: var(--color-base-dark);
    line-height: 1.7;
    margin-bottom: 0.75rem;
    max-width: 72ch;
  }
  .tr-list {
    padding-left: 1.5rem;
    margin: 0.75rem 0;
    color: var(--color-base-dark);
    line-height: 1.8;
  }
  .tr-link-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  .tr-link-list li {
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--color-base-lightest);
  }
  .tr-link-list li:last-child {
    border-bottom: none;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    border: 1px solid var(--color-base-lighter);
    border-radius: 4px;
  }
  .faq-item__question {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: var(--color-primary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item__question::after {
    content: "+";
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  details[open] .faq-item__question::after {
    content: "−";
  }
  .faq-item__answer {
    padding: 0 1.25rem 1rem;
    color: var(--color-base-dark);
    line-height: 1.7;
  }

  /* Sidebar */
  .tr-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sidebar-card {
    background: var(--color-base-lightest);
    border-left: 4px solid var(--color-primary);
    padding: 1.25rem;
    border-radius: 0 4px 4px 0;
  }
  .sidebar-card__heading {
    font-size: 1.1rem;
    color: var(--color-primary-darker);
    margin-bottom: 0.75rem;
  }
  .sidebar-card__year {
    font-size: 0.9rem;
    color: var(--color-base-dark);
    font-weight: 700;
    margin: 0.75rem 0 0.25rem;
  }
  .sidebar-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sidebar-card__list li {
    padding: 0.3rem 0;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--color-base-lighter);
  }
  .sidebar-card__list li:last-child {
    border-bottom: none;
  }
  .sidebar-card p {
    font-size: 0.9rem;
    color: var(--color-base-dark);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 900px) {
    .tr-layout__inner {
      grid-template-columns: 1fr;
    }
    .tr-sidebar {
      order: -1;
    }
  }
</style>
