  { label: "September MADiE User Group Slides", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-09/MADiE_September%202025%20User%20Group_0.pdf" },
  { label: "August MADiE User Group Slides", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-08/MADiE_August%202025%20User%20Group.pdf" },
