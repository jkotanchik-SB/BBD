const resources = [
  { label: "MADiE Access Guide", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-08/MADiEAccessGuide_v2.1.pdf" },
  { label: "MADiE User Guide", href: "https://www.emeasuretool.cms.gov/sites/default/files/2026-03/MADiE%20User%20Guide_3.0.0.pdf" },
  { label: "MADiE QI-Core Test Case User Guide", href: "https://www.emeasuretool.cms.gov/sites/default/files/2026-03/MADiE%20QI-Core%20Test%20Case%20User%20Guide_1.0.0.pdf" },
  { label: "JSON Test Case Guide", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-05/MADiETestCaseJSONGuide_v2.1.pdf" },
  { label: "Known Issues", href: "https://www.emeasuretool.cms.gov/sites/default/files/2026-01/MADiE%20Known%20Issues_01062026.pdf" },
  { label: "MADiE Enhancement Request Form for CMS Contractors", href: "https://www.emeasuretool.cms.gov/sites/default/files/2024-10/MADiE_EnhancementRequestForm_v1.0.pdf" },
  { label: "MADiE CMS ID Deletion Request Form", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-08/MADiE_CMSIDDeletion_RequestForm_v1.1.xlsx" },
  { label: "MADiE Add or Remove Measure and Library Sharing Request Form", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-11/MADiE_AddRemove_MeasureLibrary_SharingRequestForm_v1.2.xlsx" },
  { label: "MADiE Measure or Library Ownership Transfer Request Form", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-08/MADiE_MeasureorLibraryOwnershipTransferRequestForm_v2.1.xlsx" },
  { label: "MADiE Revert Measure Version Request Form", href: "https://www.emeasuretool.cms.gov/sites/default/files/2025-08/MADiE_RevertMeasureVersion_RequestForm_v1.1.xlsx" },
