---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { getResources, resourceUrl } from "../../lib/cms";

const [releaseNotes, slides, userGuides] = await Promise.all([
  getResources("release-notes"),
  getResources("user-group-slides"),
  getResources("user-guides"),
]);

// Merge all three sections into one feed
const allItems = [...releaseNotes, ...slides, ...userGuides];

// Sort by releaseDate descending; items without a date go to the end
const sorted = allItems.sort((a, b) => {
  if (a.releaseDate && b.releaseDate) {
    return new Date(b.releaseDate).getTime() - new Date(a.releaseDate).getTime();
  }
  if (a.releaseDate) return -1;
  if (b.releaseDate) return 1;
  return 0;
});

// Pagination
const PAGE_SIZE = 5;
const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
const rawPage = Number(Astro.url.searchParams.get("page") ?? 1);
const currentPage = Math.min(Math.max(1, isNaN(rawPage) ? 1 : rawPage), totalPages);
const articles = sorted.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);

function pageUrl(p: number) {
  return `/news-alerts?page=${p}`;
}

function formatDate(iso?: string): string {
  if (!iso) return "";
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

const sectionLabel: Record<string, string> = {
  "release-notes": "Release Notes",
  "user-group-slides": "User Group",
  "user-guides": "User Guide",
};
---
<BaseLayout title="News & Alerts | MADiE">
  <PageHero title="News & Alerts" />

  <section class="news-list">
    <div class="container">
      {articles.map((article) => {
        const href = resourceUrl(article);
        const date = formatDate(article.releaseDate);
        const label = sectionLabel[article.section] ?? article.section;
        return (
          <article class="news-article">
            <div class="news-article__meta">
              {date && <time class="news-article__date">{date}</time>}
              <span class="news-article__tag">{label}</span>
            </div>
            <h2 class="news-article__title">
              {href !== "#"
                ? <a href={href} target="_blank" rel="noopener noreferrer">{article.title}</a>
                : article.title
              }
            </h2>
            {article.description && (
              <p class="news-article__body">{article.description}</p>
            )}
            {href !== "#" && (
              <a href={href} class="news-article__readmore" target="_blank" rel="noopener noreferrer">Read More »</a>
            )}
          </article>
        );
      })}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          {currentPage > 1
            ? <a class="pagination__btn" href={pageUrl(currentPage - 1)}>← Previous</a>
            : <span class="pagination__btn pagination__btn--disabled">← Previous</span>
          }
          <span class="pagination__pages">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
              p === currentPage
                ? <span class="pagination__page pagination__page--active">{p}</span>
                : <a class="pagination__page" href={pageUrl(p)}>{p}</a>
            ))}
          </span>
          {currentPage < totalPages
            ? <a class="pagination__btn" href={pageUrl(currentPage + 1)}>Next →</a>
            : <span class="pagination__btn pagination__btn--disabled">Next →</span>
          }
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .news-list {
    padding: 3rem 0;
  }
  .news-article {
    border-bottom: 1px solid var(--color-base-lighter);
    padding: 2rem 0;
  }
  .news-article:first-child {
    padding-top: 0;
  }
  .news-article__date {
    display: block;
    font-size: 0.85rem;
    color: var(--color-base);
    margin-bottom: 0.4rem;
  }
  .news-article__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }
  .news-article__tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-primary-lightest, #e8f1fa);
    color: var(--color-primary-dark);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
  .news-article__title {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }
  .news-article__title a {
    color: var(--color-primary-darker);
    text-decoration: none;
  }
  .news-article__title a:hover {
    text-decoration: underline;
  }
  .news-article__body {
    color: var(--color-base-dark);
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 72ch;
  }
  .news-article__readmore {
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 0 1rem;
  }
  .pagination__btn {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-primary);
    border-radius: 3px;
    white-space: nowrap;
  }
  .pagination__btn:hover {
    background: var(--color-primary);
    color: #fff;
  }
  .pagination__btn--disabled {
    color: var(--color-base-light, #a9aeb1);
    border-color: var(--color-base-light, #a9aeb1);
    cursor: default;
    pointer-events: none;
  }
  .pagination__pages {
    display: flex;
    gap: 0.35rem;
  }
  .pagination__page {
    min-width: 2rem;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    padding: 0.3rem 0.5rem;
    border: 1px solid transparent;
    border-radius: 3px;
  }
  .pagination__page:hover {
    border-color: var(--color-primary);
  }
  .pagination__page--active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
    pointer-events: none;
  }
</style>
